#include <iostream>
#include "Math.h"

using namespace std;

int main()
{
    cout << Math::Add(3, 4) << endl;
    cout << Math::Add(1, 2, 3) << endl;
    cout << Math::Add(2.5, 3.7) << endl;
    cout << Math::Add(1.1, 2.2, 3.3) << endl;
    cout << Math::Mul(3, 4) << endl;
    cout << Math::Mul(2, 3, 4) << endl;
    cout << Math::Mul(2.5, 3.0) << endl;
    cout << Math::Mul(1.5, 2.0, 3.0) << endl;
    cout << Math::Add(4, 1, 2, 3, 4) << endl;
    cout << Math::Add(6, 10, 20, 30, 40, 50, 60) << endl;
    cout << Math::Add("OK ", "OOP");
    return 0;
}
